# Source this file before running a build or launcher:
#   set -a; source .env; set +a

SURGISABRE_DATA_ROOT=/srv/surgisabre
ISAAC_SIM_SOURCE_ROOT=/srv/surgisabre/upstream/IsaacSim
ISAAC_SIM_ROOT=/srv/surgisabre/upstream/IsaacSim/_build/linux-aarch64/release

# Directly reachable IPv4 address and a Quest-trusted DNS name for the host.
SURGISABRE_HOST_ADDRESS=REPLACE_WITH_HOST_IPV4
SURGISABRE_PUBLIC_HOSTNAME=REPLACE_WITH_TRUSTED_DNS_NAME

# A trusted certificate pair is strongly recommended. If omitted, IsaacTeleop
# creates a self-signed pair which must be accepted in the Quest browser.
SURGISABRE_TLS_CERT_PATH=/path/to/server.crt
SURGISABRE_TLS_KEY_PATH=/path/to/server.key

# Discover this loader in the built Isaac Sim or OpenXR extension cache.
ISAAC_TELEOP_OPENXR_LOADER=/path/to/libopenxr_loader.so

# Install nvidia-cusparselt-cu13 0.8.0 project-locally and point at this file.
CUSPARSELT_SOURCE=/path/to/libcusparseLt.so.0

DISPLAY=:0
XAUTHORITY=/path/to/.Xauthority

SURGISABRE_XR_ANCHOR_POS=0.0,-0.50,-1.3662
SURGISABRE_XR_NEAR_PLANE_M=0.05
ISAACTELEOP_BUILD_JOBS=8

# Set these only after reading and accepting the applicable NVIDIA terms.
ACCEPT_CLOUDXR_EULA=N
ACCEPT_OMNIVERSE_EULA=N
