+@pytest.mark.isaacsim_ci
+def test_transient_grip_descriptor_error_recovers_on_next_sample(empty_env, mock_xrcore):
+    """The exact binding readiness fault omits one side and preserves grip identity."""
+    env, _ = empty_env
+    left = mock_xrcore["left_hand"]
+    left.get_virtual_world_pose_desc.side_effect = [
+        RuntimeError("invalid parameter"),
+        mock_xrcore["controller_pose_desc"],
+    ]
+    device = OpenXRDevice(OpenXRDeviceCfg(), retargeters=[MotionControllerNoOpRetargeter(RetargeterCfg())])
+
+    first = device._get_raw_data()
+    assert DeviceBase.TrackingTarget.CONTROLLER_LEFT not in first
+    assert DeviceBase.TrackingTarget.CONTROLLER_RIGHT in first
+    assert device.controller_faults[DeviceBase.TrackingTarget.CONTROLLER_LEFT] == (
+        "_GripPoseNotReadyError: grip pose descriptor is not ready"
+    )
+
+    second = device._get_raw_data()
+    assert DeviceBase.TrackingTarget.CONTROLLER_LEFT in second
+    assert device.controller_faults[DeviceBase.TrackingTarget.CONTROLLER_LEFT] is None
+    assert [entry.args for entry in left.get_virtual_world_pose_desc.call_args_list] == [("grip",), ("grip",)]
+    left.has_pose.assert_not_called()
+
+
+@pytest.mark.isaacsim_ci
+def test_grip_descriptor_recovers_after_input_device_reconnect(empty_env, mock_xrcore):
+    """Reconnect progresses from absent to not ready to a fresh valid grip sample."""
+    env, _ = empty_env
+    singleton = mock_xrcore["singleton"]
+    left = mock_xrcore["left_hand"]
+    original_get_input_device = singleton.get_input_device.side_effect
+    left_devices = iter((None, left, left))
+
+    def reconnecting_get_input_device(path):
+        if path == "/user/hand/left":
+            return next(left_devices)
+        return original_get_input_device(path)
+
+    singleton.get_input_device.side_effect = reconnecting_get_input_device
+    left.get_virtual_world_pose_desc.side_effect = [
+        RuntimeError("invalid parameter"),
+        mock_xrcore["controller_pose_desc"],
+    ]
+    device = OpenXRDevice(OpenXRDeviceCfg(), retargeters=[MotionControllerNoOpRetargeter(RetargeterCfg())])
+
+    absent = device._get_raw_data()
+    assert DeviceBase.TrackingTarget.CONTROLLER_LEFT not in absent
+    assert device.controller_faults[DeviceBase.TrackingTarget.CONTROLLER_LEFT] == (
+        "InputDeviceUnavailable: no input device"
+    )
+    not_ready = device._get_raw_data()
+    assert DeviceBase.TrackingTarget.CONTROLLER_LEFT not in not_ready
+    assert device.controller_faults[DeviceBase.TrackingTarget.CONTROLLER_LEFT] == (
+        "_GripPoseNotReadyError: grip pose descriptor is not ready"
+    )
+    recovered = device._get_raw_data()
+    assert DeviceBase.TrackingTarget.CONTROLLER_LEFT in recovered
+    assert device.controller_faults[DeviceBase.TrackingTarget.CONTROLLER_LEFT] is None
+
+
+@pytest.mark.isaacsim_ci
+def test_nonmatching_grip_descriptor_runtime_errors_propagate(empty_env, mock_xrcore):
+    """Only the exact base RuntimeError from descriptor acquisition is transient."""
+    env, _ = empty_env
+    left = mock_xrcore["left_hand"]
+
+    class DerivedRuntimeError(RuntimeError):
+        pass
+
+    errors = (
+        RuntimeError("Invalid parameter"),
+        RuntimeError("invalid parameter "),
+        RuntimeError("invalid parameter", "extra"),
+        DerivedRuntimeError("invalid parameter"),
+    )
+    device = OpenXRDevice(OpenXRDeviceCfg(), retargeters=[MotionControllerNoOpRetargeter(RetargeterCfg())])
+    for error in errors:
+        left.get_virtual_world_pose_desc.side_effect = error
+        with pytest.raises(RuntimeError) as raised:
+            device._get_raw_data()
+        assert raised.value is error
+
+
+@pytest.mark.isaacsim_ci
+def test_invalid_parameter_from_controller_gesture_propagates(empty_env, mock_xrcore):
+    """The matching text remains fatal outside the grip descriptor call site."""
+    env, _ = empty_env
+    left = mock_xrcore["left_hand"]
+    left.has_input_gesture.side_effect = RuntimeError("invalid parameter")
+    device = OpenXRDevice(OpenXRDeviceCfg(), retargeters=[MotionControllerNoOpRetargeter(RetargeterCfg())])
+
+    with pytest.raises(RuntimeError, match="invalid parameter"):
+        device._get_raw_data()
+
+
